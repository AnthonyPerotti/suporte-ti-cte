# Suporte TI CTE — Backend Environment Variables
# Copy this file to .env and fill in the values

# ─── App ───────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ─── Database ──────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@db:5432/suporte_ti_cte"

# ─── JWT ───────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=your_access_secret_here
JWT_REFRESH_SECRET=your_refresh_secret_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Email (SMTP) ──────────────────────────────────────
# Configure after defining the sending account with the team
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=suporte-ti-cte@cead.ufsm.br
SMTP_PASS=your_smtp_password_here
SMTP_FROM="Suporte TI CTE <suporte-ti-cte@cead.ufsm.br>"

# ─── Upload ────────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10
