generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  user
  technician
  admin
}

enum TicketStatus {
  open
  in_progress
  waiting_user
  resolved
  closed
}

enum Priority {
  low
  normal
  high
  urgent
}

enum EventType {
  status_change
  assignment
  comment_added
  rating_added
  created
  attachment_added
}

model User {
  id                   String    @id @default(uuid())
  name                 String
  email                String    @unique
  password_hash        String
  role                 Role      @default(user)
  department           String?
  avatar_url           String?
  force_password_change Boolean  @default(false)
  is_active            Boolean   @default(true)
  created_at           DateTime  @default(now())
  updated_at           DateTime  @updatedAt

  tickets_created      Ticket[]          @relation("TicketCreator")
  tickets_assigned     Ticket[]          @relation("TicketAssignee")
  comments             TicketComment[]
  events               TicketEvent[]
  templates            Template[]
  articles             KnowledgeArticle[]
  calendar_events      CalendarEvent[]
  refresh_tokens       RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id         String   @id @default(uuid())
  token      String   @unique
  user_id    String
  expires_at DateTime
  created_at DateTime @default(now())

  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Category {
  id          String     @id @default(uuid())
  name        String
  description String?
  parent_id   String?
  is_archived Boolean    @default(false)
  created_at  DateTime   @default(now())

  parent      Category?  @relation("CategoryHierarchy", fields: [parent_id], references: [id])
  children    Category[] @relation("CategoryHierarchy")
  tickets     Ticket[]
  articles    KnowledgeArticle[]

  @@map("categories")
}

model Ticket {
  id           String        @id @default(uuid())
  title        String
  description  String
  status       TicketStatus  @default(open)
  priority     Priority      @default(normal)
  category_id  String?
  user_id      String
  assignee_id  String?
  rating       Int?
  rating_comment String?
  due_date     DateTime?
  is_archived  Boolean       @default(false)
  closed_at    DateTime?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  user         User          @relation("TicketCreator", fields: [user_id], references: [id])
  assignee     User?         @relation("TicketAssignee", fields: [assignee_id], references: [id])
  category     Category?     @relation(fields: [category_id], references: [id])
  attachments  TicketAttachment[]
  comments     TicketComment[]
  events       TicketEvent[]

  @@map("tickets")
}

model TicketAttachment {
  id         String   @id @default(uuid())
  ticket_id  String
  comment_id String?
  filename   String
  path       String
  mimetype   String
  size       Int
  created_at DateTime @default(now())

  ticket     Ticket         @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  comment    TicketComment? @relation(fields: [comment_id], references: [id], onDelete: Cascade)

  @@map("ticket_attachments")
}

model TicketComment {
  id          String   @id @default(uuid())
  ticket_id   String
  author_id   String
  content     String
  is_internal Boolean  @default(false)
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  ticket      Ticket   @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  author      User     @relation(fields: [author_id], references: [id])
  attachments TicketAttachment[]

  @@map("ticket_comments")
}

model TicketEvent {
  id         String    @id @default(uuid())
  ticket_id  String
  actor_id   String?
  type       EventType
  metadata   Json?
  created_at DateTime  @default(now())

  ticket     Ticket    @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  actor      User?     @relation(fields: [actor_id], references: [id])

  @@map("ticket_events")
}

model Template {
  id         String   @id @default(uuid())
  title      String
  content    String
  is_archived Boolean @default(false)
  created_by String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  author     User     @relation(fields: [created_by], references: [id])

  @@map("templates")
}

model KnowledgeArticle {
  id          String   @id @default(uuid())
  title       String
  content     String
  tags        String[]
  category_id String?
  author_id   String
  published   Boolean  @default(false)
  is_archived Boolean  @default(false)
  search_vector Unsupported("tsvector")?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  author      User     @relation(fields: [author_id], references: [id])
  category    Category? @relation(fields: [category_id], references: [id])

  @@map("knowledge_articles")
}

model CalendarEvent {
  id          String   @id @default(uuid())
  title       String
  description String?
  start_at    DateTime
  end_at      DateTime
  type        String   @default("maintenance")
  created_by  String
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt

  creator     User     @relation(fields: [created_by], references: [id])

  @@map("calendar_events")
}
